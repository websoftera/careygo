# ============================================================
# Careygo — Apache Configuration
# ============================================================

Options -Indexes -MultiViews
ServerSignature Off

# ── Error documents ──────────────────────────────────────────
ErrorDocument 404 /careygo/404.php
ErrorDocument 500 /careygo/500.php
ErrorDocument 403 /careygo/404.php

# ── Force HTTPS (uncomment on live server) ───────────────────
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Rewrite engine (needed for clean redirects) ──────────────
RewriteEngine On

# Deny direct access to sensitive directories
RewriteRule ^(config|lib|database|database\/.*\.sql)(/|$) - [F,L]

# ── Security headers ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # Strict-Transport-Security — enable on HTTPS only
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── PHP files: deny direct browsing of sensitive dirs ────────
<FilesMatch "\.(sql|log|env|bak|sh|py)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Cache static assets ──────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType image/png                 "access plus 1 month"
    ExpiresByType image/jpeg                "access plus 1 month"
    ExpiresByType image/gif                 "access plus 1 month"
    ExpiresByType image/svg+xml             "access plus 1 month"
    ExpiresByType image/x-icon             "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType application/font-woff     "access plus 1 year"
</IfModule>

# ── Compress output ──────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
